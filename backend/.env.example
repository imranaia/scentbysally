# Copy this file to .env and fill in real values. Never commit .env.

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000

# Gmail SMTP (used for order confirmations, custom-box pricing alerts, password resets)
# Use a Gmail "App Password", not the account password: https://myaccount.google.com/apppasswords
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Paystack (used in Phase 3 - not required for Phase 0/1)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Seed superadmin account (used once by `npm run seed`)
SEED_SUPERADMIN_NAME=Sally
SEED_SUPERADMIN_EMAIL=sally@scentbysally.com
SEED_SUPERADMIN_PASSWORD=change-this-before-seeding
