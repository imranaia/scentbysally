# Copy this file to .env and fill in real values. Never commit .env.

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000
# Set to "production" on a real deploy (enables secure cookies + trusts the
# proxy's HTTPS). Leave unset for local dev.
NODE_ENV=

# Where the SQLite file lives locally. Leave unset for local dev (defaults
# to backend/data/). Only used when TURSO_DATABASE_URL below is unset.
DATA_DIR=

# Turso (hosted SQLite - libsql.org). Leave both unset for local dev, which
# falls back to a local file (DATA_DIR above) with no account needed. Set
# both on a real deploy that has no persistent disk (e.g. Render Free) so
# the database survives restarts. Get these from https://turso.tech after
# creating a free database with the Turso CLI or dashboard.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Gmail SMTP (used for order confirmations, custom-box pricing alerts, password resets)
# Use a Gmail "App Password", not the account password: https://myaccount.google.com/apppasswords
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Paystack (used in Phase 3 - not required for Phase 0/1)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Seed superadmin account (used once by `npm run seed`)
SEED_SUPERADMIN_NAME=Sally
SEED_SUPERADMIN_EMAIL=sally@scentbysally.com
SEED_SUPERADMIN_PASSWORD=change-this-before-seeding
